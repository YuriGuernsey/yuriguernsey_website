---
import Layout from "../../layouts/Layout.astro";
import { normaliseTag } from "../../utils";
import { getProjects } from "../../utils/sanity";

const projects = await getProjects();
---

<Layout title="Projects" description="Featured builds and experiments from Yuri Guernsey.">
  <section class="content-page">
    <div class="content-shell">
      <a class="back-link" href="/">Back to home</a>

      <header class="content-header">
        <span class="content-overline">Portfolio</span>
        <h1 class="content-title">Projects</h1>
        <p class="content-lede">A few builds, products, and experiments that made it past the idea stage and into the real world.</p>
      </header>

      {projects.length > 0 ? (
        <div class="archive-list">
          {projects.map((project) => (
            <a class="content-entry archive-entry" href={`/project/${project.slug.current}`}>
              <div>
                <span class="entry-meta">Project</span>
                <h2 class="entry-title">{project.title}</h2>
                <p class="entry-copy">{project.excerpt || project.description || "Read the project."}</p>
              </div>

              {project.tags?.length ? (
                <div class="entry-tags archive-side">
                  {project.tags.slice(0, 3).map((tag) => (
                    <span>{normaliseTag(tag)}</span>
                  ))}
                </div>
              ) : null}
            </a>
          ))}
        </div>
      ) : (
        <p class="archive-empty">No projects published yet.</p>
      )}
    </div>
  </section>

  <style>
    .archive-list {
      padding-top: 16px;
    }

    .archive-entry {
      grid-template-columns: minmax(0, 1fr) auto;
      gap: 24px;
      align-items: start;
    }

    .archive-side {
      justify-content: flex-end;
    }

    .archive-empty {
      margin-top: 20px;
      color: rgba(244, 244, 239, 0.72);
      line-height: 1.6;
    }

    @media (max-width: 720px) {
      .archive-entry {
        grid-template-columns: 1fr;
      }

      .archive-side {
        justify-content: flex-start;
      }
    }
  </style>
</Layout>
