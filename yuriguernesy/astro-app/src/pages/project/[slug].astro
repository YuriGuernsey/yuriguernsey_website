---
import type { InferGetStaticParamsType } from "astro";
import { PortableText } from "astro-portabletext";
import Layout from "../../layouts/Layout.astro";
import { urlFor } from "../../utils/image";
import { formatDate, normaliseTag } from "../../utils";
import { getProject, getProjects } from "../../utils/sanity";

export async function getStaticPaths() {
  const projects = await getProjects();
  return projects.map((project) => ({
    params: { slug: project.slug.current },
  }));
}

type Params = InferGetStaticParamsType<typeof getStaticPaths>;
const { slug } = Astro.params as Params;

const project = await getProject(slug);
const description = project.excerpt || project.description || "Project details from Yuri Guernsey.";
const image = project.mainImage ? urlFor(project.mainImage).width(1200).height(630).fit("crop").url() : undefined;
---

<Layout title={project.title || "Project"} description={description} image={image} type="article">
  <section class="content-page">
    <div class="content-shell content-shell--narrow">
      <a class="back-link" href="/project">Back to projects</a>

      <article class="detail-article">
        {project.mainImage && (
          <img
            src={urlFor(project.mainImage).url()}
            alt={project.mainImage.alt || project.title || "Project image"}
            class="detail-cover"
          />
        )}

        <span class="content-overline">Project</span>
        <h1 class="detail-title">{project.title}</h1>
        <p class="detail-excerpt">{description}</p>
        <p class="detail-meta">{formatDate(project._createdAt)}</p>

        {project.tags?.length ? (
          <div class="detail-tags">
            {project.tags.map((tag) => (
              <span>{normaliseTag(tag)}</span>
            ))}
          </div>
        ) : null}

        <div class="rich-text">
          <PortableText value={project.body} />
        </div>
      </article>
    </div>
  </section>
</Layout>
