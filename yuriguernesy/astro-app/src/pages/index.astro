---
import { PortableText } from "astro-portabletext";
import Layout from "../layouts/Layout.astro";
import { urlforFile } from "../utils/image";
import { formatRange, normaliseTag, toPlainText } from "../utils";
import { getBlogPosts, getExperience, getHomepage, getProjects } from "../utils/sanity";
import type { ActionLink, SectionIntro } from "../utils/sanity";

const posts = await getBlogPosts();
const projects = await getProjects();
const jobs = await getExperience();
const home = await getHomepage();
const cvURL = await urlforFile();

const featuredPosts = posts.slice(0, 4);
const featuredJobs = jobs.slice(0, 6);

const brandPrefix = home?.brandPrefix?.trim() || "Yuri";
const brandAccent = home?.brandAccent?.trim() || "Guernsey";
const brandMeta = home?.brandMeta?.trim() || "Portfolio / 2026";

const heroEyebrow = home?.heroEyebrow?.trim() || "Guernsey based / working worldwide";
const heroTitle = home?.heroTitle?.trim() || "I build real systems in days, not months.";
const heroSummary =
  home?.herosubheading?.trim() ||
  "Mobile apps, automation systems, AI workflows, and experiments that actually ship. Based in Guernsey. Built for real problems, not pitch decks.";
const heroCurrentTitle = home?.heroSubtitle?.trim() || "Founder / Product builder";
const heroCurrentDescription =
  home?.heroparagraph?.trim() ||
  "Legocia, Aevea, and a rotating backlog of useful experiments. Shipping across software, automation, and hardware.";

const defaultFocusTags = ["Flutter", "AI agents", "Automation", "Hardware", "Local SaaS"];
const focusTags = (home?.focusTags?.length ? home.focusTags : defaultFocusTags).map((tag) => normaliseTag(tag));

function withDefaultSection(section: SectionIntro | undefined, fallback: Required<SectionIntro>) {
  return {
    overline: section?.overline?.trim() || fallback.overline,
    title: section?.title?.trim() || fallback.title,
    description: section?.description?.trim() || fallback.description,
  };
}

function withDefaultAction(action: ActionLink | undefined, fallback: Required<ActionLink>) {
  return {
    label: action?.label?.trim() || fallback.label,
    href: action?.href?.trim() || fallback.href,
    variant: action?.variant || fallback.variant,
  };
}

const heroPrimaryAction = withDefaultAction(home?.heroPrimaryAction, {
  label: "Featured work",
  href: "#projects",
  variant: "primary",
});

const heroSecondaryAction = home?.heroSecondaryAction?.href
  ? withDefaultAction(home.heroSecondaryAction, {
      label: "Operating manual",
      href: "#about",
      variant: "secondary",
    })
  : cvURL
    ? {
        label: home?.heroSecondaryAction?.label?.trim() || "Download resume",
        href: `${cvURL}?dl`,
        variant: "secondary",
      }
    : withDefaultAction(home?.heroSecondaryAction, {
        label: "Operating manual",
        href: "#about",
        variant: "secondary",
      });

const projectsSection = withDefaultSection(home?.projectsSection, {
  overline: "Current bets",
  title: "Featured projects",
  description:
    "Three active directions: a privacy-first wearable, an automation-first agency model, and a stream of practical software experiments.",
});

const workSection = withDefaultSection(home?.workSection, {
  overline: "Selected roles",
  title: "Work",
  description: "Startups, enterprise systems, and founder mode. Different environments, same delivery bias.",
});

const notesSection = withDefaultSection(home?.notesSection, {
  overline: "Process",
  title: "Build logs, experiments & rants",
  description: "No fluff. Just the process, the systems, the failures, and the ideas worth testing properly.",
});

const aboutSection = withDefaultSection(home?.aboutSection, {
  overline: "Long form",
  title: "You want to know more? OK.",
  description: "The broad picture, the working style, and the systems behind the shipping bias.",
});

const connectSection = withDefaultSection(home?.connectSection, {
  overline: "Elsewhere",
  title: "Let's connect",
  description: "Got an idea? A project? A weird challenge? Use this section for contact points, profiles, and the next obvious click.",
});

const connectPrimaryAction = withDefaultAction(home?.connectPrimaryAction, {
  label: "Featured work",
  href: "#projects",
  variant: "primary",
});

const connectSecondaryAction = withDefaultAction(home?.connectSecondaryAction, {
  label: "View all posts",
  href: "/post",
  variant: "secondary",
});

const defaultFeatureCards = [
  {
    posterLabel: "Legocia",
    ribbonTags: ["Privacy first", "Wearable", "Always on"],
    posterSummary: "Continuous life capture, sensitive-content redaction, and secure personal memory recall.",
    title: "Legocia",
    description: "A long-term product bet on remembering more without turning life into surveillance.",
    tags: ["AI redaction", "Raspberry Pi", "Secure storage"],
    href: "#work",
  },
  {
    posterLabel: "Agency OS",
    ribbonTags: ["Automation first", "Ops", "Delivery"],
    posterSummary:
      "AI agents handling sales, onboarding, support, and service delivery until a human decision actually matters.",
    title: "Aevea operating model",
    description: "An agency system designed for operational leverage instead of more manual overhead.",
    tags: ["n8n", "Lead automation", "Productised services"],
    href: "#work",
  },
  {
    posterLabel: "Useful builds",
    ribbonTags: ["Local SaaS", "Utility", "Experiments"],
    posterSummary:
      "Boring-but-useful software, Guernsey-focused tools, and slightly unhinged side projects with a point.",
    title: "Useful experiments",
    description:
      "From OnTheTinkle to GympleBuddy to scheduling assistants, the point is always the same: ship fast and learn from reality.",
    tags: ["OnTheTinkle", "GympleBuddy", "Scheduling agents"],
    href: "#notes",
  },
];

const projectDocCards = projects.slice(0, 3).map((project) => ({
  posterLabel: project.title || "Project",
  ribbonTags: project.tags?.slice(0, 3)?.map((tag) => normaliseTag(tag)) || ["Featured"],
  posterSummary: project.description || project.excerpt || "Read the project.",
  title: project.title || "Project",
  description: project.excerpt || project.description || "Read the project.",
  tags: project.tags?.slice(0, 3)?.map((tag) => normaliseTag(tag)) || [],
  href: `/project/${project.slug.current}`,
}));

const featureCards = (home?.featuredProjectCards?.length
  ? home.featuredProjectCards.map((card) => ({
      posterLabel: card.posterLabel || card.title || "Feature",
      ribbonTags: (card.ribbonTags?.length ? card.ribbonTags : card.tags || ["Featured"]).map((tag) => normaliseTag(tag)),
      posterSummary: card.posterSummary || card.description || "",
      title: card.title || card.posterLabel || "Feature",
      description: card.description || card.posterSummary || "",
      tags: (card.tags || []).map((tag) => normaliseTag(tag)),
      href: card.href || "#projects",
    }))
  : [...projectDocCards, ...defaultFeatureCards]).slice(0, 3);

const defaultNoteCards = [
  {
    meta: "Wearable systems / 2026",
    title: "How do you capture more of life without building surveillance?",
    description: "The Legocia problem space: memory, privacy, redaction, and the reality of always-on devices.",
    linkLabel: "Read the project",
    href: "#projects",
  },
  {
    meta: "Agency ops / 2026",
    title: "Can an agency run mostly on agents?",
    description: "Sales, onboarding, support, and delivery workflows pushed toward automation without losing judgment.",
    linkLabel: "Read the work",
    href: "#work",
  },
  {
    meta: "Local software / 2026",
    title: "Why boring Guernsey utilities are worth building",
    description: "Small local problems are still real problems, and often easier to validate than shiny global ideas.",
    linkLabel: "Read the thinking",
    href: "#about",
  },
  {
    meta: "Experiments / ongoing",
    title: "Useful, weird, or slightly unhinged. Preferably all three.",
    description:
      "OnTheTinkle, GympleBuddy, scheduling assistants, subscription concepts, and whatever survives contact with users.",
    linkLabel: "Read the current mode",
    href: "#connect",
  },
];

const noteCards = home?.noteCards?.length
  ? home.noteCards.map((card) => ({
      meta: card.meta || "Build log",
      title: card.title || "Untitled note",
      description: card.description || "",
      linkLabel: card.linkLabel || "Read more",
      href: card.href || "#notes",
    })).slice(0, 4)
  : featuredPosts.length
    ? featuredPosts.map((post) => ({
        meta: `${post.tags?.[0] ? normaliseTag(post.tags[0]) : "Build log"} / ${new Date(post._createdAt).getFullYear()}`,
        title: post.title || "Untitled post",
        description: post.excerpt || "Read the post.",
        linkLabel: "Read more",
        href: `/post/${post.slug.current}`,
      })).slice(0, 4)
    : defaultNoteCards;

const aboutPanels = home?.aboutPanels?.length
  ? home.aboutPanels.filter((panel) => panel?.label && panel?.body?.length)
  : [
      ...(home?.moreAboutMeHighlights?.length
        ? [{label: "Highlights", body: home.moreAboutMeHighlights}]
        : []),
      ...(home?.moreAboutMeLifeMission?.length
        ? [{label: "Life mission", body: home.moreAboutMeLifeMission}]
        : []),
    ];

const defaultManualGroups = [
  {
    label: "Languages & frameworks",
    items: [
      "Flutter, React, React Native, Astro, Next.js, Tailwind",
      "Node.js, Python, PHP",
      "PostgreSQL, Supabase, Drizzle, Prisma",
    ],
  },
  {
    label: "Tools & platforms",
    items: [
      "Docker, VPS hosting, Traefik, Coolify",
      "Cloudflare Workers and CI/CD pipelines",
      "Workflow tooling across n8n, Zapier, and Make",
    ],
  },
  {
    label: "AI & automation",
    items: [
      "OpenAI APIs and custom assistants",
      "Prompt engineering and workflow orchestration",
      "Ops automation for sales, onboarding, support, and delivery",
    ],
  },
  {
    label: "Hardware & experimental",
    items: [
      "Raspberry Pi and Arduino builds",
      "Real-time video processing and AI redaction pipelines",
      "Products that need more than a browser and a database",
    ],
  },
  {
    label: "Builder rules",
    items: [
      "Ship fast, iterate faster",
      "Build real things, not just ideas",
      "Prefer simple systems over clever ones",
    ],
  },
  {
    label: "Interesting bits",
    items: [
      "Founder of Legocia, a privacy-first wearable memory product",
      "Building an automation-heavy agency operating model",
      "Comfortable moving between product, code, systems, and hardware",
    ],
  },
];

const manualGroups = (home?.manualGroups?.length ? home.manualGroups : defaultManualGroups).filter(
  (group) => group?.label && group?.items?.length
);

const defaultConnectCards = [
  {
    label: "Platform",
    title: "GitHub",
    description: "github.com/YuriGuernsey",
    href: "https://github.com/YuriGuernsey",
  },
  {
    label: "Profile",
    title: "LinkedIn",
    description: "Add your LinkedIn URL in Studio",
  },
  {
    label: "Asset",
    title: "Resume",
    description: "Upload your CV in Home settings to make this live",
  },
  {
    label: "Updates",
    title: "Build logs",
    description: "Posts, experiments, and process notes",
    href: "/post",
  },
];

const connectCards = (home?.connectCards?.length ? home.connectCards : defaultConnectCards)
  .filter((card) => card?.title)
  .map((card) => ({
    label: card.label || "Elsewhere",
    title: card.title || "Link",
    description: card.description || "",
    href: card.href?.trim(),
  }));

const lifeMissionText =
  toPlainText(home?.moreAboutMeLifeMission) ||
  "Build tools that help people, automate the boring parts, and leave better systems behind so the next builder does not have to start from scratch.";

const aboutDescription = aboutSection.description?.trim();

function getJobSummary(job: (typeof featuredJobs)[number]) {
  const summary =
    toPlainText(job.body) ||
    `${job.employmentType ? `${job.employmentType} role.` : "Role."} ${job.location ? `Based in ${job.location}.` : ""}`.trim();

  return summary.length > 210 ? `${summary.slice(0, 207).trimEnd()}...` : summary;
}
---

<Layout title={home?.seoTitle || "Portfolio 2026"} description={heroSummary}>
  <div class="home-shell">
    <header class="home-header">
      <div class="home-header__inner">
        <a class="home-brand" href="#top" aria-label="Yuri Guernsey portfolio home">
          <strong>{brandPrefix} <span>{brandAccent}</span></strong>
          <small>{brandMeta}</small>
        </a>

        <nav class="home-nav" aria-label="Primary">
          <a href="#projects">Projects</a>
          <a href="#work">Work</a>
          <a href="#notes">Logs</a>
          <a href="#about">About</a>
          <a href="#connect">Connect</a>
        </nav>
      </div>
    </header>

    <section class="home-hero" id="top">
      <div class="home-hero__grid">
        <div class="home-hero__main reveal">
          {(home?.lookingForWork || home?.availableForFreelance) && <p class="home-status">Open for hire</p>}
          <p class="home-eyebrow">{heroEyebrow}</p>
          <h1>{heroTitle.replace("days", "")}{heroTitle.includes("days") ? <><em>days</em>{heroTitle.split("days")[1]}</> : null}</h1>
          <p class="home-summary">{heroSummary}</p>

          <div class="home-actions">
            <a class:list={["home-btn", heroPrimaryAction.variant === "primary" && "home-btn--primary"]} href={heroPrimaryAction.href}>
              {heroPrimaryAction.label}
            </a>
            <a class:list={["home-btn", heroSecondaryAction.variant === "primary" && "home-btn--primary"]} href={heroSecondaryAction.href}>
              {heroSecondaryAction.label}
            </a>
          </div>
        </div>

        <aside class="home-hero__side reveal">
          <div class="home-block">
            <span class="home-label">Currently</span>
            <h2>{heroCurrentTitle}</h2>
            <p>{heroCurrentDescription}</p>
          </div>

          <div class="home-block">
            <span class="home-label">Focus</span>
            <div class="home-pill-row">
              {focusTags.map((tag) => (
                <span class="home-pill">{tag}</span>
              ))}
            </div>
          </div>

          <div class="home-block">
            <span class="home-label">Life mission</span>
            {home?.moreAboutMeLifeMission?.length ? (
              <div class="portable-copy portable-copy--compact">
                <PortableText value={home.moreAboutMeLifeMission} />
              </div>
            ) : (
              <p>{lifeMissionText}</p>
            )}
          </div>
        </aside>
      </div>
    </section>

    <section class="home-section" id="projects">
      <div class="home-section__head reveal">
        <div>
          <span class="home-overline">{projectsSection.overline}</span>
          <h2>{projectsSection.title}</h2>
        </div>
        <p>{projectsSection.description}</p>
      </div>

      <div class="home-projects">
        {featureCards.map((card) => (
          <a class="home-project-card reveal" href={card.href}>
            <div class="home-project-poster" data-mark={card.posterLabel}>
              <div class="home-ribbon">
                {(card.ribbonTags?.length ? card.ribbonTags : card.tags || ["Featured"]).slice(0, 3).map((tag) => (
                  <span>{tag}</span>
                ))}
              </div>
              <p class="home-poster-copy">{card.posterSummary || card.description}</p>
            </div>
            <div class="home-project-body">
              <h3>{card.title}</h3>
              <p>{card.description}</p>
              {card.tags?.length ? (
                <div class="home-tag-row">
                  {card.tags.slice(0, 3).map((tag) => (
                    <span>{tag}</span>
                  ))}
                </div>
              ) : null}
            </div>
          </a>
        ))}
      </div>
    </section>

    <section class="home-section" id="work">
      <div class="home-section__head reveal">
        <div>
          <span class="home-overline">{workSection.overline}</span>
          <h2>{workSection.title}</h2>
        </div>
        <p>{workSection.description}</p>
      </div>

        <div class="home-work-list">
        {featuredJobs.length ? (
          featuredJobs.map((job) => (
            <article class="home-work-row reveal">
              <div class="home-work-badge">{formatRange(job.startDate, job.endDate, job.currentlyEmployed)}</div>
              <div class="home-work-main">
                <h3>{job.title}</h3>
                <div class="home-work-company">{job.company}</div>
                <p>{getJobSummary(job)}</p>
              </div>
              <div class="home-work-stack">
                {job.employmentType && <span>{normaliseTag(job.employmentType)}</span>}
                {job.location && <span>{job.location}</span>}
                <span>{job.currentlyEmployed ? "Current" : "Completed"}</span>
              </div>
            </article>
          ))
        ) : (
          <p class="home-empty reveal">Add experience entries in Sanity to populate the work ledger.</p>
        )}
      </div>
    </section>

    <section class="home-section" id="notes">
      <div class="home-section__head reveal">
        <div>
          <span class="home-overline">{notesSection.overline}</span>
          <h2>{notesSection.title}</h2>
        </div>
        <p>{notesSection.description}</p>
      </div>

      <div class="home-notes">
        {noteCards.map((card) => (
          <a class="home-note-card reveal" href={card.href}>
            <span class="home-card-meta">{card.meta}</span>
            <h3>{card.title}</h3>
            <p>{card.description}</p>
            <span class="home-note-link">{card.linkLabel}</span>
          </a>
        ))}
      </div>
    </section>

    <section class="home-section" id="about">
      <div class="home-about">
        <div class="home-about__intro reveal">
          <span class="home-overline">{aboutSection.overline}</span>
          <h2>{aboutSection.title}</h2>
          {aboutDescription ? <p class="home-about-lead">{aboutDescription}</p> : null}
          {home?.moreAboutMe?.length ? (
            <div class="portable-copy">
              <PortableText value={home.moreAboutMe} />
            </div>
          ) : (
            <>
              <p>
                I am a Guernsey-based builder working across software, automation, and experimental hardware.
                I prefer shipping over over-engineering, momentum over ceremony, and real-world testing over theory.
              </p>
              <p>
                The work ranges from mobile apps and internal systems to AI workflows and edge-device experiments,
                but the principle is consistent: build something useful, keep it understandable, and automate anything repetitive.
              </p>
            </>
          )}
        </div>

        <div class="home-about__content reveal">
          {aboutPanels.length ? (
            <div class="home-about-panels">
              {aboutPanels.map((panel) => (
                <div class="home-about-panel">
                  <span class="home-list-label">{panel.label}</span>
                  {panel.body?.length ? (
                    <div class="portable-copy portable-copy--compact">
                      <PortableText value={panel.body} />
                    </div>
                  ) : null}
                </div>
              ))}
            </div>
          ) : null}

          <div class="home-manual">
            {manualGroups.map((group) => (
              <div class="home-manual-group">
                <span class="home-list-label">{group.label}</span>
                <ul>
                  {group.items?.map((item) => (
                    <li>{item}</li>
                  ))}
                </ul>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>

    <section class="home-section home-section--last" id="connect">
      <div class="home-connect">
        <div class="home-connect__copy reveal">
          <span class="home-overline">{connectSection.overline}</span>
          <h2>{connectSection.title}</h2>
          <p>{connectSection.description}</p>

          <div class="home-actions">
            <a class:list={["home-btn", connectPrimaryAction.variant === "primary" && "home-btn--primary"]} href={connectPrimaryAction.href}>
              {connectPrimaryAction.label}
            </a>
            <a class:list={["home-btn", connectSecondaryAction.variant === "primary" && "home-btn--primary"]} href={connectSecondaryAction.href}>
              {connectSecondaryAction.label}
            </a>
          </div>
        </div>

        <div class="home-connect__cards">
          {connectCards.map((card) => (
            card.href ? (
              <a class="home-connect-card reveal" href={card.href}>
                <span class="home-card-meta">{card.label}</span>
                <h3>{card.title}</h3>
                <p>{card.description}</p>
              </a>
            ) : (
              <article class="home-connect-card reveal">
                <span class="home-card-meta">{card.label}</span>
                <h3>{card.title}</h3>
                <p>{card.description}</p>
              </article>
            )
          ))}
        </div>
      </div>
    </section>

    <footer class="home-footer">
      <span>{brandPrefix} {brandAccent} / 2026</span>
      <span>Built fast. Refined in production.</span>
    </footer>
  </div>

  <script is:inline>
    document.documentElement.classList.add("js");

    const prefersReducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
    const revealTargets = document.querySelectorAll(".reveal");

    if (!prefersReducedMotion) {
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add("is-visible");
              observer.unobserve(entry.target);
            }
          });
        },
        {
          threshold: 0.14,
          rootMargin: "0px 0px -10% 0px",
        }
      );

      revealTargets.forEach((target) => observer.observe(target));
    } else {
      revealTargets.forEach((target) => target.classList.add("is-visible"));
    }
  </script>

  <style>
    .home-shell {
      width: min(calc(100% - 40px), 1240px);
      margin: 0 auto;
      padding-bottom: 28px;
    }

    .home-header {
      padding: 32px 0 12px;
    }

    .home-header__inner {
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
      gap: 24px;
    }

    .home-brand {
      text-decoration: none;
      display: grid;
      gap: 8px;
      line-height: 1;
    }

    .home-brand strong {
      font-size: clamp(1.8rem, 3vw, 2.4rem);
      font-weight: 700;
      letter-spacing: -0.06em;
      text-transform: uppercase;
    }

    .home-brand strong span {
      color: var(--accent);
    }

    .home-brand small,
    .home-nav a,
    .home-eyebrow,
    .home-status,
    .home-label,
    .home-overline,
    .home-card-meta,
    .home-work-badge,
    .home-list-label,
    .home-pill,
    .home-tag-row span,
    .home-work-stack span,
    .home-footer {
      font-size: 0.76rem;
      letter-spacing: 0.14em;
      text-transform: uppercase;
    }

    .home-brand small,
    .home-eyebrow,
    .home-label,
    .home-overline,
    .home-card-meta,
    .home-list-label {
      color: var(--muted);
    }

    .home-nav {
      display: flex;
      flex-wrap: wrap;
      justify-content: flex-end;
      gap: 10px 18px;
      padding-top: 6px;
    }

    .home-nav a {
      color: rgba(244, 244, 239, 0.72);
      text-decoration: none;
      transition: color 150ms ease;
    }

    .home-nav a:hover,
    .home-nav a:focus-visible {
      color: var(--accent);
    }

    .home-hero {
      padding: 34px 0 56px;
    }

    .home-hero__grid,
    .home-about,
    .home-connect {
      display: grid;
      grid-template-columns: minmax(0, 1.15fr) minmax(300px, 0.85fr);
      gap: clamp(28px, 5vw, 64px);
      align-items: start;
    }

    .home-status {
      display: inline-flex;
      align-items: center;
      min-height: 32px;
      padding: 0 12px;
      border-radius: 999px;
      border: 1px solid rgba(255, 230, 0, 0.28);
      background: rgba(255, 230, 0, 0.1);
      color: var(--accent);
      margin-bottom: 18px;
    }

    .home-hero__main h1,
    .home-section__head h2,
    .home-block h2,
    .home-project-body h3,
    .home-work-main h3,
    .home-note-card h3,
    .home-about__intro h2,
    .home-connect__copy h2,
    .home-connect-card h3 {
      margin: 0;
      font-weight: 700;
      letter-spacing: -0.08em;
      text-transform: uppercase;
    }

    .home-hero__main h1 {
      margin-top: 10px;
      font-size: clamp(3.6rem, 8vw, 6.8rem);
      line-height: 0.92;
      max-width: 9ch;
    }

    .home-hero__main h1 em {
      color: var(--accent);
      font-style: normal;
    }

    .home-summary {
      margin-top: 18px;
      max-width: 38rem;
      font-size: 1rem;
