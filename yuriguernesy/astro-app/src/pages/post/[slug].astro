---
import type { InferGetStaticParamsType } from "astro";
import { PortableText } from "astro-portabletext";
import Layout from "../../layouts/Layout.astro";
import { urlFor } from "../../utils/image";
import { formatDate, normaliseTag } from "../../utils";
import { getBlogPost, getBlogPosts } from "../../utils/sanity";

export async function getStaticPaths() {
  const posts = await getBlogPosts();
  return posts.map((post) => ({
    params: { slug: post.slug.current },
  }));
}

type Params = InferGetStaticParamsType<typeof getStaticPaths>;
const { slug } = Astro.params as Params;

const post = await getBlogPost(slug);
const description = post.excerpt || "Build notes and experiments from Yuri Guernsey.";
---

<Layout title={post.title || "Build log"} description={description}>
  <section class="content-page">
    <div class="content-shell content-shell--narrow">
      <a class="back-link" href="/post">Back to posts</a>

      <article class="detail-article">
        {post.mainImage && (
          <img
            src={urlFor(post.mainImage).url()}
            alt={post.mainImage.alt || post.title || "Post image"}
            class="detail-cover"
          />
        )}

        <span class="content-overline">Build log</span>
        <h1 class="detail-title">{post.title}</h1>
        <p class="detail-excerpt">{description}</p>
        <p class="detail-meta">{formatDate(post._createdAt)}</p>

        {post.tags?.length ? (
          <div class="detail-tags">
            {post.tags.map((tag) => (
              <span>{normaliseTag(tag)}</span>
            ))}
          </div>
        ) : null}

        <div class="rich-text">
          <PortableText value={post.body} />
        </div>
      </article>
    </div>
  </section>
</Layout>
