---
import Layout from "../../layouts/Layout.astro";
import { normaliseTag } from "../../utils";
import { getBlogPosts } from "../../utils/sanity";

const posts = await getBlogPosts();
---

<Layout title="Build logs" description="Build logs, experiments, and process notes from Yuri Guernsey.">
  <section class="content-page">
    <div class="content-shell">
      <a class="back-link" href="/">Back to home</a>

      <header class="content-header">
        <span class="content-overline">Process</span>
        <h1 class="content-title">Build logs, experiments &amp; rants</h1>
        <p class="content-lede">No fluff. Just the process, the problems, the systems, and the ideas that survive contact with reality.</p>
      </header>

      {posts.length > 0 ? (
        <div class="archive-list">
          {posts.map((post) => (
            <a class="content-entry archive-entry" href={`/post/${post.slug.current}`}>
              <div>
                <span class="entry-meta">{new Date(post._createdAt).getFullYear()}</span>
                <h2 class="entry-title">{post.title}</h2>
                <p class="entry-copy">{post.excerpt || "Read the post."}</p>
              </div>

              {post.tags?.length ? (
                <div class="entry-tags archive-side">
                  {post.tags.slice(0, 3).map((tag) => (
                    <span>{normaliseTag(tag)}</span>
                  ))}
                </div>
              ) : null}
            </a>
          ))}
        </div>
      ) : (
        <p class="archive-empty">No posts published yet.</p>
      )}
    </div>
  </section>

  <style>
    .archive-list {
      padding-top: 16px;
    }

    .archive-entry {
      grid-template-columns: minmax(0, 1fr) auto;
      gap: 24px;
      align-items: start;
    }

    .archive-side {
      justify-content: flex-end;
    }

    .archive-empty {
      margin-top: 20px;
      color: rgba(244, 244, 239, 0.72);
      line-height: 1.6;
    }

    @media (max-width: 720px) {
      .archive-entry {
        grid-template-columns: 1fr;
      }

      .archive-side {
        justify-content: flex-start;
      }
    }
  </style>
</Layout>
