---
import { ViewTransitions } from "astro:transitions";
import { urlFor } from "../utils/image";
import { getSettings } from "../utils/sanity";

interface Props {
  title?: string;
  description?: string;
  image?: string;
  type?: "website" | "article";
  noIndex?: boolean;
}

const settings = await getSettings();

const {
  title = settings?.defaultTitle?.trim() || "Portfolio 2026",
  description =
    settings?.defaultDescription?.trim() ||
    "Yuri Alves is a Guernsey-based builder creating practical software, automation systems, and experimental hardware.",
  image,
  type = "website",
  noIndex = false,
} = Astro.props;

const siteName = settings?.siteName?.trim() || "Yuri Guernsey";
const siteUrl = settings?.siteUrl?.trim().replace(/\/$/, "") || "https://yuriguernsey.com";
const pageTitle = title.startsWith(siteName) ? title : `${siteName} | ${title}`;
const canonicalUrl = new URL(`${Astro.url.pathname}${Astro.url.search}`, siteUrl).toString();
const themeColor = settings?.themeColor?.trim() || "#040404";
const twitterHandle = settings?.twitterHandle?.trim();
const defaultSocialImage = settings?.defaultOgImage
  ? urlFor(settings.defaultOgImage).width(1200).height(630).fit("crop").url()
  : "";
const socialImage = image?.trim() || defaultSocialImage;
const socialImageUrl = socialImage
  ? socialImage.startsWith("http")
    ? socialImage
    : new URL(socialImage, siteUrl).toString()
  : "";
const faviconUrl = settings?.faviconUrl?.trim() || "/favicon.svg";
const appleTouchIconUrl = settings?.appleTouchIconUrl?.trim();
const twitterCard = socialImageUrl ? "summary_large_image" : "summary";

function getFileType(url: string) {
  const extension = url.split("?")[0]?.split(".")?.pop()?.toLowerCase();

  if (extension === "svg") return "image/svg+xml";
  if (extension === "png") return "image/png";
  if (extension === "ico") return "image/x-icon";
  return undefined;
}

const faviconType = getFileType(faviconUrl);
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="icon" href={faviconUrl} type={faviconType} />
    <link rel="shortcut icon" href={faviconUrl} />
    {appleTouchIconUrl ? <link rel="apple-touch-icon" href={appleTouchIconUrl} /> : null}
    <meta name="generator" content={Astro.generator} />
    <meta name="theme-color" content={themeColor} />
    <meta name="description" content={description} />
    <meta name="title" content={pageTitle} />
    <meta name="robots" content={noIndex ? "noindex, nofollow" : "index, follow"} />

    <meta property="og:type" content={type} />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    {socialImageUrl ? <meta property="og:image" content={socialImageUrl} /> : null}

    <meta property="twitter:card" content={twitterCard} />
    <meta property="twitter:url" content={canonicalUrl} />
    <meta property="twitter:title" content={pageTitle} />
    <meta property="twitter:description" content={description} />
    {twitterHandle ? <meta property="twitter:site" content={twitterHandle} /> : null}
    {twitterHandle ? <meta property="twitter:creator" content={twitterHandle} /> : null}
    {socialImageUrl ? <meta property="twitter:image" content={socialImageUrl} /> : null}

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin="" />
    <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;700&display=swap" rel="stylesheet" />

    <title>{pageTitle}</title>

    <ViewTransitions />

    <style is:global>
      :root {
        --bg: #040404;
        --panel: #0b0b0b;
        --panel-soft: #111111;
        --text: #f4f4ef;
        --muted: #a1a19a;
        --line: rgba(255, 255, 255, 0.16);
        --line-soft: rgba(255, 255, 255, 0.08);
        --accent: #ffe600;
        --accent-soft: rgba(255, 230, 0, 0.16);
        --max: 1240px;
        --radius: 12px;
      }

      * {
        box-sizing: border-box;
      }

      html {
        scroll-behavior: smooth;
      }

      body {
        margin: 0;
        min-height: 100vh;
        background: var(--bg);
        color: var(--text);
        font-family: "Space Grotesk", system-ui, sans-serif;
        overflow-x: hidden;
      }

      body::before {
        content: "";
        position: fixed;
        inset: 0;
        background:
          linear-gradient(90deg, transparent 0 6%, rgba(255, 255, 255, 0.03) 6% 6.08%, transparent 6.08% 100%),
          linear-gradient(180deg, transparent 0 8%, rgba(255, 255, 255, 0.03) 8% 8.08%, transparent 8.08% 100%);
        opacity: 0.3;
        pointer-events: none;
        z-index: 0;
      }

      main {
        position: relative;
        z-index: 1;
      }

      a {
        color: inherit;
      }

      img {
        display: block;
        max-width: 100%;
      }

      .content-page {
        padding: 42px 0 68px;
      }

      .content-shell {
        width: min(calc(100% - 40px), 1080px);
        margin: 0 auto;
      }

      .content-shell--narrow {
        width: min(calc(100% - 40px), 860px);
      }

      .back-link {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        margin-bottom: 22px;
        color: rgba(244, 244, 239, 0.74);
        text-decoration: none;
        font-size: 0.78rem;
        font-weight: 700;
        letter-spacing: 0.14em;
        text-transform: uppercase;
      }

      .content-header {
        display: grid;
        gap: 10px;
        padding-bottom: 18px;
        border-bottom: 1px solid var(--line);
      }

      .content-overline,
      .entry-meta,
      .detail-meta,
      .detail-tags span {
        font-size: 0.78rem;
        letter-spacing: 0.14em;
        text-transform: uppercase;
      }

      .content-overline,
      .entry-meta,
      .detail-meta {
        color: var(--muted);
      }

      .content-title,
      .detail-title {
        margin: 0;
        font-size: clamp(2.4rem, 6vw, 4.6rem);
        line-height: 0.94;
        font-weight: 700;
        letter-spacing: -0.08em;
        text-transform: uppercase;
      }

      .content-lede,
      .detail-excerpt {
        max-width: 44rem;
        color: rgba(244, 244, 239, 0.76);
        line-height: 1.68;
      }

      .content-list {
        display: grid;
        gap: 0;
        padding-top: 16px;
      }

      .content-entry {
        display: grid;
        gap: 10px;
        padding: 18px 0 20px;
        border-bottom: 1px solid var(--line-soft);
        text-decoration: none;
        transition: transform 160ms ease, border-color 160ms ease;
      }

      .content-entry:hover {
        transform: translateX(6px);
        border-color: rgba(255, 230, 0, 0.3);
      }

      .entry-title {
        margin: 0;
        font-size: 1.35rem;
        line-height: 1;
        font-weight: 700;
        letter-spacing: -0.05em;
        text-transform: uppercase;
      }

      .entry-copy {
        color: rgba(244, 244, 239, 0.72);
        line-height: 1.64;
      }

      .entry-tags,
      .detail-tags {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
      }

      .entry-tags span,
      .detail-tags span {
        display: inline-flex;
        align-items: center;
        min-height: 30px;
        padding: 0 10px;
        border-radius: 999px;
        border: 1px solid rgba(255, 255, 255, 0.18);
        color: rgba(244, 244, 239, 0.84);
      }

      .detail-article {
        padding-top: 8px;
      }

      .detail-cover {
        width: 100%;
        max-height: 440px;
        object-fit: cover;
        border-radius: var(--radius);
        border: 1px solid var(--line);
        background: var(--panel);
        margin-bottom: 24px;
      }

      .detail-excerpt {
        margin-top: 14px;
      }

      .detail-meta {
        margin-top: 16px;
      }

      .detail-tags {
        margin-top: 16px;
      }

      .rich-text {
        margin-top: 28px;
        color: rgba(244, 244, 239, 0.78);
        line-height: 1.8;
      }

      .rich-text h2,
      .rich-text h3 {
        margin: 2rem 0 0.8rem;
        font-size: 1.45rem;
        line-height: 1.1;
        font-weight: 700;
        letter-spacing: -0.04em;
        text-transform: uppercase;
      }

      .rich-text p,
      .rich-text ul,
      .rich-text ol,
      .rich-text blockquote {
        margin: 0 0 1rem;
      }

      .rich-text ul,
      .rich-text ol {
        padding-left: 1.25rem;
      }

      .rich-text li + li {
        margin-top: 0.45rem;
      }

      .rich-text a {
        color: var(--accent);
      }

      @media (max-width: 720px) {
        .content-page {
          padding: 28px 0 52px;
        }

        .content-shell,
        .content-shell--narrow {
          width: min(calc(100% - 28px), 1080px);
        }

        .content-title,
        .detail-title {
          font-size: clamp(2rem, 12vw, 3.2rem);
        }
      }
    </style>
  </head>
  <body>
    <main>
      <slot />
    </main>
  </body>
</html>
